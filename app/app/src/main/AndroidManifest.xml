<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network: TMDB, Torrentio, Real-Debrid CDNs -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Wake lock so playback survives if the user steps away briefly -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Sage v2 commandment: TV must NOT require touch -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!-- Tell the launcher we are a Leanback (TV) app -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />

    <application
        android:name=".ScrudioApp"
        android:allowBackup="true"
        android:banner="@drawable/app_banner"
        android:icon="@drawable/app_icon"
        android:label="@string/app_name"
        android:logo="@drawable/app_banner"
        android:supportsRtl="true"
        android:theme="@style/Theme.Scrudio.Leanback"
        android:hardwareAccelerated="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <!-- LEANBACK_LAUNCHER = appears in the Android TV "apps" row -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.details.DetailsActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode" />

        <activity
            android:name=".ui.sources.SourcesActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode" />

        <activity
            android:name=".ui.playback.PlaybackActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Scrudio.Playback"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Scrudio.Settings"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode" />

        <activity
            android:name=".ui.seasons.SeasonsActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode" />

        <activity
            android:name=".ui.seasons.EpisodesActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode" />

        <activity
            android:name=".ui.pair.PairActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode" />

        <activity
            android:name=".ui.search.SearchActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|uiMode" />

    </application>
</manifest>
