<?xml version="1.0" encoding="utf-8"?>
<!-- Both states use a dark sage fill so light text stays readable. The
     focused state adds a brighter sage primary border to call out focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/sage_browse_actions" />
            <stroke android:width="3dp" android:color="@color/sage_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33000000" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
        </shape>
    </item>
</selector>
