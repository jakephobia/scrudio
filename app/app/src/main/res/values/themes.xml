<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base TV theme. Inherits from Leanback's stock Browse theme so the
      headers panel, focus highlights and back-press handling all work.
      Custom palette is layered on top via colorPrimary / android:colorBackground.
    -->
    <style name="Theme.Scrudio.Leanback" parent="Theme.Leanback.Browse">
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="defaultBrandColor">@color/sage</item>
        <item name="browseTitleTextStyle">@style/Scrudio.Browse.Title</item>
        <item name="rowHeaderStyle">@style/Scrudio.Browse.RowHeader</item>
    </style>

    <style name="Scrudio.Browse.Title" parent="Widget.Leanback.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Scrudio.Browse.RowHeader" parent="Widget.Leanback.Header">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Fullscreen black background for playback. -->
    <style name="Theme.Scrudio.Playback" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Leanback preference theme. The parent already wires the right
         preferenceTheme overlay for LeanbackPreferenceFragmentCompat. -->
    <style name="Theme.Scrudio.Settings" parent="Theme.Leanback" />
</resources>
