<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="800dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="20dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@drawable/source_row_background"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/row_quality"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:textColor="@color/sage_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@color/sage_surface_variant"
        android:padding="8dp"
        tools:ignore="HardcodedText"
        android:text="1080p" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="20dp">

        <TextView
            android:id="@+id/row_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/row_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/sage_primary_muted"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>
</LinearLayout>
