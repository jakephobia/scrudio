<?xml version="1.0" encoding="utf-8"?>
<!--
  Pairing screen layout.

  Left column: instructions + giant user-code + status line.
  Right column: QR code (points to direct_verification_url so the phone
  doesn't even need to type the user_code).

  Everything sits on the dark sage background; the QR card is a white tile
  for max contrast against any phone camera.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center"
    android:background="@color/sage_browse_background"
    android:padding="48dp">

    <!-- ── Left column: instructions + code ─────────────────────────────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="start|center_vertical">

        <TextView
            android:id="@+id/pair_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/sage_surface"
            android:textSize="34sp"
            android:textStyle="bold"
            android:text="@string/pair_title" />

        <TextView
            android:id="@+id/pair_step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:textColor="@color/sage_primary_muted"
            android:textSize="20sp"
            android:text="@string/pair_step1" />

        <TextView
            android:id="@+id/pair_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/sage_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textIsSelectable="false"
            tools:ignore="HardcodedText"
            xmlns:tools="http://schemas.android.com/tools"
            android:text="real-debrid.com/device" />

        <TextView
            android:id="@+id/pair_step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/sage_primary_muted"
            android:textSize="20sp"
            android:text="@string/pair_step2" />

        <TextView
            android:id="@+id/pair_user_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/sage_focus_glow"
            android:textSize="64sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:typeface="monospace"
            android:text="•••••" />

        <TextView
            android:id="@+id/pair_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:textColor="@color/sage_surface"
            android:textSize="18sp"
            android:text="@string/pair_status_init" />

    </LinearLayout>

    <!-- ── Right column: QR card ────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:padding="20dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/pair_qr"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:contentDescription="@string/pair_qr_description" />
    </FrameLayout>

</LinearLayout>
