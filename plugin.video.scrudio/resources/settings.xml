<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="plugin.video.scrudio">

        <category id="api" label="30200" help="">
            <group id="1" label="30210">
                <setting id="tmdb_api_key" type="string" label="30211" help="">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string">
                        <heading>30211</heading>
                    </control>
                </setting>
                <setting id="tmdb_language" type="string" label="30212" help="">
                    <level>0</level>
                    <default>it-IT</default>
                    <constraints>
                        <options>
                            <option label="Italiano">it-IT</option>
                            <option label="English">en-US</option>
                        </options>
                    </constraints>
                    <control type="list" format="string"/>
                </setting>
            </group>
            <group id="2" label="30220">
                <setting id="rd_api_key" type="string" label="30221" help="">
                    <level>0</level>
                    <default></default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string">
                        <heading>30221</heading>
                    </control>
                </setting>
            </group>
        </category>

        <category id="catalog" label="30300" help="">
            <group id="1" label="30300">
                <setting id="quality_4k" type="boolean" label="30301" help="">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="quality_1080p" type="boolean" label="30302" help="">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="quality_720p" type="boolean" label="30303" help="">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="quality_480p" type="boolean" label="30304" help="">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="hide_no_seeds" type="boolean" label="30310" help="">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
            </group>
        </category>

        <category id="cache" label="30400" help="">
            <group id="1" label="30400">
                <setting id="cache_ttl_hours" type="integer" label="30401" help="">
                    <level>0</level>
                    <default>6</default>
                    <constraints>
                        <minimum>1</minimum>
                        <maximum>168</maximum>
                        <step>1</step>
                    </constraints>
                    <control type="slider" format="integer">
                        <formatlabel>30402</formatlabel>
                    </control>
                </setting>
                <setting id="cache_clear" type="action" label="30410" help="">
                    <level>0</level>
                    <data>RunPlugin(plugin://plugin.video.scrudio/?action=cache_clear)</data>
                    <control type="button" format="action">
                        <heading>30410</heading>
                    </control>
                </setting>
            </group>
        </category>

    </section>
</settings>
